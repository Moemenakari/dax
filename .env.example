# ─── FRONTEND / ADMIN ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ─── BACKEND — MySQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=dax_db

# ─── BACKEND — Auth ──────────────────────────────────────────────────
JWT_SECRET=your-very-secret-jwt-key
NODE_ENV=development

# ─── BACKEND — Cloudinary (image hosting) ───────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── BACKEND — Email (SMTP for password reset & order confirmation) ──
# Works with Gmail, Outlook, Mailtrap, etc.
# For Gmail: enable "App Passwords" and use your app password here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ─── BACKEND — URLs ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
